generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  color     String   @default("#6366f1")
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  familyMemberships FamilyMember[]
  assignedTasks     Issue[]        @relation("AssignedIssues")
  reviewedTasks     Issue[]        @relation("ReviewedIssues")
  createdTasks      Issue[]        @relation("CreatedIssues")
  comments          Comment[]
  ownedMyTasks      MyTask[] @relation("MyTaskOwner")
  assignedMyTasks   MyTask[] @relation("MyTaskAssignee")
  pushSubscriptions PushSubscription[]
}

model Family {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members  FamilyMember[]
  projects Project[]
}

model FamilyMember {
  id       String     @id @default(cuid())
  role     FamilyRole @default(MEMBER)
  nickname String

  userId   String
  familyId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, familyId])
  @@index([userId])
  @@index([familyId])
}

model Project {
  id          String  @id @default(cuid())
  name        String
  description String?
  key         String

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  sprints Sprint[]
  issues  Issue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([familyId, key])
}

model Sprint {
  id        String       @id @default(cuid())
  name      String
  goal      String?
  status    SprintStatus @default(PLANNING)
  startDate DateTime?
  endDate   DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  issues Issue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Issue {
  id          String      @id @default(cuid())
  title       String
  description String?
  status      IssueStatus @default(READY)
  priority    Priority    @default(MEDIUM)
  points      Float       @default(1)
  order       Float       @default(0)
  dueDate     DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  assigneeId String?
  assignee   User?   @relation("AssignedIssues", fields: [assigneeId], references: [id], onDelete: SetNull)

  reviewerId String?
  reviewer   User?   @relation("ReviewedIssues", fields: [reviewerId], references: [id], onDelete: SetNull)

  creatorId String?
  creator   User?   @relation("CreatedIssues", fields: [creatorId], references: [id], onDelete: SetNull)

  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([projectId, sprintId])
  @@index([sprintId, status])
}

model Comment {
  id         String  @id @default(cuid())
  content    String
  type       String  @default("COMMENT")
  fromStatus String?
  toStatus   String?

  issueId  String
  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FamilyRole {
  MASTER
  MEMBER
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

enum IssueStatus {
  READY
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
  HOLD
  FAILED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  DONE
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
}

enum AcceptStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model MyTask {
  id           String       @id @default(cuid())
  title        String
  memo         String?
  priority     Priority     @default(MEDIUM)
  status       TaskStatus   @default(PENDING)
  acceptStatus AcceptStatus @default(ACCEPTED)
  dueDate      DateTime?
  repeat       RepeatType   @default(NONE)
  ownerId      String
  owner        User         @relation("MyTaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  assigneeId   String?
  assignee     User?        @relation("MyTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([ownerId, dueDate])
  @@index([assigneeId])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  endpoint     String   @unique
  p256dh       String
  auth         String
  reminderHour Int      @default(21)
  enabled      Boolean  @default(true)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([userId])
}
